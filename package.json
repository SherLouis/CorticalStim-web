{
  "name": "cortical_stim_web",
  "version": "0.1.0",
  "homepage": "https://SherLouis.github.io/CorticalStim-web/",
  "private": true,
  "dependencies": {
    "@dotenvx/dotenvx": "^1.21.1",
    "@mantine/core": "^6.0.22",
    "@mantine/dates": "^6.0.22",
    "@mantine/form": "^6.0.22",
    "@mantine/hooks": "^6.0.22",
    "@mantine/notifications": "^6.0.22",
    "@tabler/icons-react": "^2.42.0",
    "firebase": "^10.14.1",
    "i18next": "^23.7.6",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-http-backend": "^2.4.2",
    "lodash.sortby": "^4.7.0",
    "mantine-datatable": "^6.0.8",
    "natural-compare": "^1.4.0",
    "react": "^18.2.0",
    "react-csv": "^2.2.2",
    "react-dom": "^18.2.0",
    "react-i18next": "^13.5.0",
    "react-router-dom": "^6.19.0"
  },
  "scripts": {
    "predeploy": "dotenvx run --env-file=config/.env.prod -- react-scripts build",
    "deploy": "gh-pages -d build",
    "start": "react-scripts start",
    "dev:start_emulators": "firebase emulators:start",
    "dev:start": "dotenvx run --env-file=config/.env.dev -- react-scripts start",
    "dev": "npm-run-all --parallel dev:start_emulators dev:start",
    "build": "dotenvx run --env-file=config/.env.prod -- react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.14.1",
    "@testing-library/react": "^13.0.0",
    "@testing-library/user-event": "^13.2.1",
    "@types/jest": "^29.5.9",
    "@types/lodash.sortby": "^4.7.9",
    "@types/natural-compare": "^1.4.3",
    "@types/node": "^20.9.3",
    "@types/react": "^18.2.38",
    "@types/react-csv": "^1.1.10",
    "@types/react-dom": "^18.2.16",
    "dotenv": "^16.4.5",
    "gh-pages": "^6.1.0",
    "npm-run-all": "^4.1.5",
    "react-scripts": "5.0.1",
    "ts-jest": "^29.3.0",
    "typescript": "^4.5.4"
  }
}
